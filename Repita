algoritmo "repita"

var
  valor: inteiro = 0
  valorComanda: inteiro = 0
  comandaAberta: logico = verdadeiro
  
  podeConsumir: logico


inicio
  repita
    escreval("Quanto foi gasto?")
    leia(valor)
    valorComanda <- valorComanda + valor
    escreval("Valor gasto: " + valor)
    escreval("Quer fechar a comanda?")
    leia(comandaAberta)
  ate (comandaAberta)

  escreval("Valor total: " + valorComanda)

  valorComanda <- 0

  escreval("Usuario pode consumir?")
  leia(podeConsumir)

  enquanto (podeConsumir) faca
    escreval("Quanto foi gasto?")
    leia(valor)
    valorComanda <- valorComanda + valor
    escreval("Valor gasto: " + valor)

    escreval("Ainda pode consumir?")
    leia(podeConsumir)
  fimenquanto

  escreval("Valor total: " + valorComanda)

fimalgoritmo
