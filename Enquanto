algoritmo "enquanto"

var
  i: inteiro
  j: inteiro
  notas: vetor[0..3] de inteiro
  media: inteiro = 0
   
inicio
  enquanto (i <= 3) faca
    escreval("Digite a nota ", i + 1, ": ")
    leia(notas[i])
    i <- i + 1
  fimenquanto

  enquanto (j <= 3) faca
    media <- media + notas[j]
    escreval("Nota ", i, ": ", notas[j])
    j <- j + 1
  fimenquanto

  media <- media / 4
  escreval("Media do aluno é: " + media)

fimalgoritmo
